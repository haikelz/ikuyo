{
  "extends": ["astro/tsconfigs/strict", "@ikuyo/typescript/base.json"],
  "compilerOptions": {
    "baseUrl": ".",
    "noUnusedParameters": false,
    "noUnusedLocals": false,
    "paths": {
      "@/*": ["./src/*"],
      "@ikuyo/ui": ["./index.ts"],
      "@ikuyo/ui/*": ["./src/components/ui/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
