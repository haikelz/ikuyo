---
import Footer from "@/components/Footer.astro";
import CodeBlockCopy from "@/components/svelte/CodeBlockCopy.svelte";
import Navbar from "@/components/svelte/Navbar.svelte";
import { PUBLIC_GOATCOUNTER_SRC } from "@/utils/env";
import "@fontsource/geist-mono";
import "@fontsource/geist-sans";
import "@fontsource/noto-naskh-arabic";
import "../index.css";
import { ClientRouter } from "astro:transitions";

type Props = {
  title: string;
  description: string;
  url: string;
  ogImage?: string;
  className?: string;
};

const { title, description, url, ogImage, className = "max-w-6xl!" } = Astro.props;
const currentPath = Astro.url.pathname;
const resolvedOgImage = `https://ekel.dev/og/${ogImage ?? "home.png"}`;

const removedFilenameGoatcounterSrc = PUBLIC_GOATCOUNTER_SRC.split(".").slice(0, 3).join(".");
---

<!doctype html>
<html lang="en">
  <head>
    <title>{title}</title>
    <meta charset="UTF-8" />
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:alt" content="ekel.dev opengraph image" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:secure_url" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={resolvedOgImage} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap.xml" />
    <script
      is:inline
      defer
      data-goatcounter={removedFilenameGoatcounterSrc}
      async
      src={PUBLIC_GOATCOUNTER_SRC}></script>
    <script is:inline>
      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

      const applyTheme = () => {
        const stored = localStorage.getItem('theme');
        const theme = stored === 'light' || stored === 'dark' || stored === 'system'
          ? stored
          : 'system';
        const isDark = theme === 'dark' || (theme === 'system' && mediaQuery.matches);

        document.documentElement.classList.toggle('dark', isDark);
      };

      applyTheme();
      mediaQuery.addEventListener('change', applyTheme);
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
    <ClientRouter  />
  </head>
  <body class="w-full flex flex-col justify-start items-start" transition:animate="initial" >
    <div class="hidden md:block fixed inset-0 w-full h-full pointer-events-none z-0" aria-hidden="true">
      <div class="mx-auto max-w-6xl h-full relative">
        <div class="absolute inset-0 border-x border-border/70"></div>
        <div class="absolute left-1/4 top-0 bottom-0 border-l border-dashed border-border/70" style="border-left-width: 0.5px"></div>
        <div class="absolute left-1/2 top-0 bottom-0 border-l border-dashed border-border/70" style="border-left-width: 0.5px"></div>
        <div class="absolute left-3/4 top-0 bottom-0 border-l border-dashed border-border/70" style="border-left-width: 0.5px"></div>
      </div>
    </div>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-background focus:text-foreground focus:rounded-lg focus:ring-2 focus:ring-ring focus:outline-none"
      >Skip to content</a
    >
    <CodeBlockCopy client:only="svelte" />
    <Navbar currentPath={currentPath} client:only="svelte" />
    <div
      class:list={[
        "container mx-auto w-full! px-4 sm:px-6 md:px-8 pt-24 relative",
        className,
      ]}
    >
      <main
        id="main-content"
        tabindex="-1"
        class="flex min-h-dvh w-full relative items-start justify-center"
      >
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
