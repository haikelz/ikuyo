---
import Footer from "@/components/Footer.astro";
import Banner from "@/components/svelte/Banner.svelte";
import CodeBlockCopy from "@/components/svelte/CodeBlockCopy.svelte";
import Navbar from "@/components/svelte/Navbar.svelte";
import "@fontsource/geist-mono";
import "@fontsource/geist-sans";
import "@fontsource/noto-naskh-arabic";
import { ClientRouter } from "astro:transitions";
import "../index.css";

type Props = {
  title: string;
  description: string;
  url: string;
  ogImage?: string;
  className?: string;
};

const { title, description, url, ogImage, className = "max-w-6xl!" } = Astro.props;
const currentPath = Astro.url.pathname;
const resolvedOgImage = `https://ekel.dev/og/${ogImage ?? "home.png"}`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <title>{title}</title>
    <meta charset="UTF-8" />
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:alt" content="ekel.dev opengraph image" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:secure_url" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={resolvedOgImage} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap.xml" />
    <ClientRouter />
  </head>
  <body class="w-full flex flex-col justify-start items-start relative">
    <div class="page-bg-grid" aria-hidden="true"></div>
    <CodeBlockCopy client:only="svelte" />
    <Banner client:only="svelte" />
    <Navbar currentPath={currentPath} client:only="svelte" />
    <div
      class:list={[
        "prose prose-base container mx-auto w-full! px-4 md:pt-8 pt-20 prose-invert relative z-10",
        className,
      ]}
    >
      <main
        class="flex min-h-screen w-full relative items-start justify-center leading-[1.75] tracking-wide"
      >
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
