---
import BackButton from "@/components/svelte/BackButton.svelte";
import ReadingIndicator from "@/components/svelte/ReadingIndicator.svelte";
import TOC from "@/components/svelte/TOC.svelte";
import { sanitizeSlug } from "@/helpers/slug";
import Layout from "@/layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { format } from "date-fns";

export async function getStaticPaths() {
  const notesEntries = await getCollection("notes");

  return notesEntries.map((item) => ({
    params: {
      slug: item.id,
    },
    props: {
      item,
    },
  }));
}

const { item } = Astro.props;
const { Content, remarkPluginFrontmatter, headings } = await render(item);

const slug = sanitizeSlug(item.id);
---

<ReadingIndicator client:only="svelte" />
<Layout
  title={item.data.title}
  description={item.data.description}
  url={`https://ekel.dev/notes/${slug}`}
  ogImage={`notes/${slug}.png`}
>
  <div class="w-full  mx-auto slide-enter-content">
    <BackButton label="back to notes" client:only="svelte" />
    <article>
      <header class="mb-12">
        <h1 class="mt-8 mb-4 text-3xl sm:text-4xl tracking-tighter font-medium text-foreground leading-tight">
          {item.data.title}
        </h1>
        <p class="text-sm text-muted-foreground mb-0 space-x">
          {item.data.author}, {format(item.data.created_at, "LLLL d yyyy")} - {remarkPluginFrontmatter.minutesRead}
        </p>
        <div class="flex items-center gap-2 mt-4 flex-wrap">
          {item.data.tags.map((tag) => (
            <a href={`/tags/${tag}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors">#{tag}</a>
          ))}
        </div>
        <p class="arabic-font text-right text-lg font-medium mt-12 text-muted-foreground">
        بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ
        </p>
      </header>
      <div class="prose prose-neutral dark:prose-invert max-w-none text-justify prose-code:text-sm prose-pre:bg-muted prose-pre:border prose-pre:border-border/40">
        <Content />
      </div>
   </article>
  </div>
  {
    headings && headings.length > 0 ? (
      <TOC headings={headings} client:only="svelte" />
    ) : null
  }
</Layout>
