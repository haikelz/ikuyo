---
import PhotosPage from "@/components/svelte/PhotosPage.svelte";
import Layout from "@/layouts/Layout.astro";
import { getAllPhotos } from "@/utils/imagekit";

const images = await getAllPhotos();
const photos = images.map(({ url, thumbnail }) => ({ url, thumbnail }));
---

<Layout
  title="Photos"
  description="Photos"
  url="https://ekel.dev/photos"
  ogImage="photos.png"
>
  <div
    class="flex w-full flex-col items-start justify-start mx-auto md:text-start"
  >
    <section class="w-full">
      <PhotosPage client:only="svelte" photos={photos} />
    </section>
  </div>
</Layout>
