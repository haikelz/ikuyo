---
import PhotoGrid from "@/components/svelte/PhotoGrid.svelte";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Uses"
  description="My current usage of stuffs."
  url="https://ekel.dev/uses"
  ogImage="uses.png"
>
  <div
    class:list={[
      "flex w-full flex-col items-start justify-start",
      "md:text-start",
    ]}
  >
    <section class="w-full">
      <h1 data-cy="heading" class="mb-0">./uses</h1>
      <div class="slide-enter-content">
        <p data-cy="description" class="mb-0 text-justify">
          My current usage of stuffs.
        </p>
      </div>
    </section>
    <section class="w-full slide-enter-content">
      <PhotoGrid
        client:only
        images={[
          "/images/uses.png",
          "/images/IMG_1205.png",
          "/images/hobby-related.jpeg",
          "/images/IMG_1267.png",
        ]}
      />
      <ul>
        <li>
          <p class="py-0!">
            <b><u>IDE/Text Editor:</u></b> Trae/Cursor/Neovim.
          </p>
        </li>
        <li>
          <p class="py-0!">
             <b><u>Laptop:</u></b> Lenovo Thinkbook 14 G2 ARE (Ryzen 4500U)
            with <b>24GB of RAM</b> (8GB soldered + 16GB Kingston Fury Impact) and
            <b>1TB of Storage</b> (512GB Samsung NVME + 512GB Team Elite EX2 Elite
            SATA 2.5).
          </p>
        </li>
        <li>
          <p class="py-0!">
             <b><u>Mouse:</u></b> Logitech Pebble M350 (2022).
          </p>
        </li>
        <li>
          <p class="py-0!">
             <b><u>Mech Keyboard:</u></b> <strike>Royal Kludge RKG68 (2022)</strike> Noir Timeless82 V1 (Used Barebone) + Akko V3 Cream Blue Pro.
          </p>
        </li>
        <li>
          <p class="py-0!">
             <b><u>Dualboot OS:</u></b>
            (Fedora Linux + Windows 10 Home Edition).
          </p>
        </li>
        <li>
          <p class="py-0!">
             <b><u>Phone:</u></b> <strike>Sony Xperia X Compact</strike> Iphone SE 3 2022.
          </p>
        </li>
        <li>
          <p class="py-0!">
             <b><u>Camera:</u></b> Sony A5000 + TTArtisan 56mm f/1.8.
          </p>
        </li>
        <li>
          <p class="py-0!">
             <b><u>Audio:</u></b> Moondrop Chu2 + Modular Pula Unicrom Cable + <strike
              >DAC Fiio JA11 (SOLD)</strike
            > Moondrop Dawn Pro + C to Lightning Akliam C5 / DAP Fiio Snowsky Echo
            Mini.
          </p>
        </li>
      </ul>
    </section>
  </div>
</Layout>
