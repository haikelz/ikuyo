---
import Card from "@/components/card.astro";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const notes = await getCollection("notes");

export async function getStaticPaths() {
  const notesEntries = await getCollection("notes");

  const tags = [
    ...new Set(
      notesEntries
        .map((item) => [...new Set(item.data.tags)].join(" "))
        .join(" ")
        .split(" "),
    ),
  ].sort((a, b) => {
    if (a > b) return 1;
    if (a < b) return -1;
    return 0;
  });

  return tags.map((item) => ({
    params: { slug: item },
    props: { item },
  }));
}

const currentPath = Astro.url.pathname.split("/")[2];
---

<Layout
  title={`Notes with tag ${currentPath}`}
  description="Notes with tag"
  url={`https://ekel.dev/tags/${currentPath}`}
  ogImage={`tags/${currentPath}.png`}
>
  <div class="w-full mx-auto slide-enter-content">
    <section class="w-full mt-8">
      <h1 class="mb-4 mt-0 text-3xl sm:text-4xl tracking-tighter font-bold text-foreground">
        #{currentPath}
      </h1>
      <p class="mb-0 text-lg sm:text-xl text-muted-foreground">
        Notes tagged with {currentPath}.
      </p>
    </section>

    <section class="w-full mt-10 sm:mt-16">
      <div class="grid w-full grid-cols-1 sm:grid-cols-2 gap-6 slide-enter-content">
        {
          notes
            .filter((item) => item.data.tags.includes(currentPath))
            .sort(
              (a, b) =>
                new Date(b.data.created_at).getTime() -
                new Date(a.data.created_at).getTime(),
            )
            .map((item) => (
              <Card
                title={item.data.title}
                description={item.data.description}
                type="notes"
                slug={item.id}
                createdAt={item.data.created_at}
                tags={item.data.tags}
              />
            ))
        }
      </div>
    </section>
  </div>
</Layout>
