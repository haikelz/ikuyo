---
import GuestbookMessages from "@/components/svelte/Guestbook.svelte";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Guestbook"
  description="Write a message for me and others."
  url="https://ekel.dev/guestbook"
  ogImage="guestbook.png"
>
  <div class="w-full max-w-3xl mx-auto">
    <section class="w-full mb-10 sm:mb-16">
      <h1
        data-cy="heading"
        class="mb-4 mt-0 text-3xl sm:text-4xl tracking-tighter font-bold text-foreground"
      >
        Guestbook
      </h1>
      <p
        data-cy="description"
        class="mb-0 text-lg sm:text-xl text-muted-foreground"
      >
        Write a message for me and others. Go to
        <a
          target="_blank"
          rel="noopener noreferrer"
          aria-label="guestbook.ekel.dev (opens in new tab)"
          href="https://guestbook.ekel.dev"
          class="text-foreground font-medium hover:text-muted-foreground transition-colors"
          >guestbook.ekel.dev</a
        > to add your message.
      </p>
    </section>
    <section
      data-cy="guestbook"
      class="flex w-full flex-col space-y-6 sm:space-y-8 items-start justify-start"
    >
      <GuestbookMessages client:load />
    </section>
  </div>
</Layout>
