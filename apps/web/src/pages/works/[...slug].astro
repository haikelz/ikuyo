---
import BackButton from "@/components/svelte/BackButton.svelte";
import ReadingIndicator from "@/components/svelte/ReadingIndicator.svelte";
import TOC from "@/components/svelte/TOC.svelte";
import { sanitizeSlug } from "@/helpers/slug";
import Layout from "@/layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const worksEntries = await getCollection("works");

  return worksEntries.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(item);

const slug = sanitizeSlug(item.id);
---

<ReadingIndicator client:only="svelte" />
<Layout
  title={item.data.title}
  description={item.data.description}
  url={`https://ekel.dev/works/${slug}`}
  ogImage={`works/${slug}.png`}
>
  <div class="w-full mx-auto slide-enter-content">
    <BackButton label="back to works" client:only="svelte" />
    <h1
      class="mt-8 mb-6 text-3xl sm:text-4xl md:text-5xl tracking-tighter font-medium text-foreground leading-tight"
    >
      {item.data.title}
    </h1>
    <div
      class="flex w-full items-center gap-3 mb-8 text-sm sm:text-base text-muted-foreground"
    >
      <span class="font-medium text-foreground">{item.data.author}</span>
      <span>{remarkPluginFrontmatter.minutesRead}</span>
      {
        item.data.preview ? (
          <a
            href={item.data.preview}
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-foreground hover:text-muted-foreground transition-colors"
          >
            Preview
          </a>
        ) : null
      }
      {
        item.data.repo ? (
          <a
            href={item.data.repo}
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-foreground hover:text-muted-foreground transition-colors"
          >
            Source
          </a>
        ) : null
      }
    </div>
    <div class="flex items-center gap-2 mt-8 flex-wrap">
      {
        item.data.stack.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors no-underline"
          >
            #{tag}
          </a>
        ))
      }
    </div>
    <p
      class="arabic-font text-right text-lg sm:text-xl font-medium mt-8 text-muted-foreground"
    >
      بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ
    </p>
    <div
      class="prose-content text-base sm:text-lg leading-7 sm:leading-relaxed text-foreground prose-a:font-medium prose-a:underline prose-code:text-sm"
    >
      <Content />
    </div>
  </div>
  {
    headings && headings.length > 0 ? (
      <TOC headings={headings} client:only="svelte" />
    ) : null
  }
</Layout>
