{
  "extends": ["astro/tsconfigs/strict", "@ikuyo/typescript/base.json"],
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "noUnusedParameters": false,
    "noUnusedLocals": false,
    "paths": {
      "@/*": ["./src/*"],
      "@ikuyo/ui": ["../../packages/ui/index.ts"],
      "@ikuyo/ui/*": ["../../packages/ui/src/components/ui/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "exclude": ["dist"]
}
